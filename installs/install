#!/usr/bin/env bash

# --- Configurable options ---
IS_USER=false
NO_PROMPT=false
REPO="JohanChane/clashtui"
BRANCH="main"
CORE_TYPE="all"
SERVICE_CONTROLLER="systemd"
BACKED_UP_LIST=()

# --- Constants (canonical upstreams) ---
MIHOMO_UPSTREAM="MetaCubeX/mihomo"
SINGBOX_UPSTREAM="SagerNet/sing-box"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
  echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $1" >&2
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

backup_dir() {
  [ -d "$1" ] || return 0
  local i=1
  while [ -d "${1}_$i" ]; do
    ((i++))
  done
  cp -r "$1" "${1}_$i"
  log_info "Backed up directory: $1 -> ${1}_$i"
  BACKED_UP_LIST+=("$1 -> ${1}_$i")
}

backup_file() {
  [ -e "$1" ] || return 1
  local i=1
  while [ -e "${1}_$i" ]; do
    ((i++))
  done
  mv "$1" "${1}_$i"
  BACKED_UP_LIST+=("$1 -> ${1}_$i")
}

# --- Resolve all paths based on current options ---
resolve_paths() {
  detect_is_macos

  if $IS_USER; then
    INSTALL_DIR="$HOME/.local/clashtui"
    INSTALL_DIR_MIHOMO="$INSTALL_DIR/mihomo"
    INSTALL_DIR_SINGBOX="$INSTALL_DIR/sing-box"
    MIHOMO_CONFIG_DIR="$INSTALL_DIR_MIHOMO/config"
    SINGBOX_CONFIG_DIR="$INSTALL_DIR_SINGBOX/config"
    SUDO=""
    SERVICE_IS_USER=true
    if $IS_MACOS; then
      UNIT_DIR="$HOME/Library/LaunchAgents"
      SERVICE_LOAD_CMD=""
      SERVICE_UNLOAD_CMD="launchctl unload"
      SERVICE_ENABLE_CMD="launchctl load -w"
      LAUNCHD_DOMAIN="gui/\$(id -u)"
    elif [ "$SERVICE_CONTROLLER" = "openrc" ]; then
      UNIT_DIR="/etc/user/init.d"
      SERVICE_LOAD_CMD=""
      SERVICE_UNLOAD_CMD=""
      SERVICE_ENABLE_CMD="rc-update --user add"
    else
      SYSTEMCTL_FLAGS="--user"
      UNIT_DIR="$HOME/.config/systemd/user"
      SYSTEMD_RELOAD="systemctl --user daemon-reload"
      UNIT_WANTED_BY="default.target"
      SERVICE_LOAD_CMD=""
      SERVICE_UNLOAD_CMD=""
      SERVICE_ENABLE_CMD="systemctl --user enable"
    fi
  else
    if $IS_MACOS; then
      INSTALL_DIR="/usr/local/opt/clashtui"
      UNIT_DIR="/Library/LaunchDaemons"
      SUDO="sudo"
      SERVICE_LOAD_CMD=""
      SERVICE_UNLOAD_CMD="sudo launchctl unload"
      SERVICE_ENABLE_CMD="sudo launchctl load -w"
      LAUNCHD_DOMAIN="system"
    else
      INSTALL_DIR="/opt/clashtui"
      SUDO="sudo"
      SERVICE_LOAD_CMD=""
      SERVICE_UNLOAD_CMD=""
      if [ "$SERVICE_CONTROLLER" = "openrc" ]; then
        UNIT_DIR="/etc/init.d"
        SERVICE_ENABLE_CMD="sudo rc-update add"
      else
        UNIT_DIR="/usr/lib/systemd/system"
        SYSTEMCTL_FLAGS=""
        SYSTEMD_RELOAD="sudo systemctl daemon-reload"
        UNIT_WANTED_BY="multi-user.target"
        SERVICE_ENABLE_CMD="sudo systemctl enable"
      fi
    fi
    INSTALL_DIR_MIHOMO="$INSTALL_DIR/mihomo"
    INSTALL_DIR_SINGBOX="$INSTALL_DIR/sing-box"
    MIHOMO_CONFIG_DIR="$INSTALL_DIR_MIHOMO/config"
    SINGBOX_CONFIG_DIR="$INSTALL_DIR_SINGBOX/config"
    SERVICE_IS_USER=false
  fi

  CLASHTUI_CONFIG_DIR="${CLASHTUI_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/clashtui}"
  MIHOMO_USER_CONFIG_DIR="$CLASHTUI_CONFIG_DIR/mihomo"
  SINGBOX_USER_CONFIG_DIR="$CLASHTUI_CONFIG_DIR/sing-box"

  INSTALL_BIN="$INSTALL_DIR/bin"
  CLASHTUI_BIN="$INSTALL_BIN/clashtui"

  SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
  if [ -d "$SCRIPT_DIR/contrib" ]; then
    CONTRIB_SOURCE="local"
    CONTRIB_DIR="$SCRIPT_DIR/contrib"
  elif [ -d "$SCRIPT_DIR/../contrib" ]; then
    CONTRIB_SOURCE="local"
    CONTRIB_DIR="$SCRIPT_DIR/../contrib"
  else
    CONTRIB_SOURCE="remote"
    CONTRIB_DIR=""
  fi

  CONTRIB_URL_PREFIX="https://raw.githubusercontent.com/${REPO}/refs/heads/${BRANCH}/contrib"
}

# --- copy_contrib: copy from local contrib or download from remote ---
# Usage: copy_contrib <relative_path_in_contrib> <destination_path>
copy_contrib() {
  local rel_path="$1"
  local dest="$2"
  local src

  if [ "$CONTRIB_SOURCE" = "local" ]; then
    src="$CONTRIB_DIR/$rel_path"
    if [ -f "$src" ]; then
      cp "$src" "$dest"
      return 0
    fi
    log_warn "Local file not found: $src, falling back to remote"
  fi

  local remote_url="${CONTRIB_URL_PREFIX}/${rel_path}"
  curl -sSL --fail -o "$dest" "$remote_url" || {
    log_error "Failed to download: $remote_url"
    return 1
  }
  return 0
}

# --- CPU / OS detection ---
detect_architecture() {
  local arch
  arch=$(uname -m)
  case "$arch" in
  x86_64 | amd64) echo "amd64" ;;
  aarch64 | arm64) echo "arm64" ;;
  armv7l | armhf) echo "armv7" ;;
  armv6l) echo "armv6" ;;
  i386 | i686) echo "386" ;;
  *) echo "unsupported" ;;
  esac
}

detect_os() {
  local os
  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  case "$os" in
  linux) echo "linux" ;;
  darwin) echo "darwin" ;;
  freebsd) echo "freebsd" ;;
  *) echo "unsupported" ;;
  esac
}

IS_MACOS=false
detect_is_macos() {
  [ "$(detect_os)" = "darwin" ] && IS_MACOS=true || IS_MACOS=false
}

detect_cpu_level_using_proc() {
  local flags=$(grep -m 1 '^flags' /proc/cpuinfo 2>/dev/null | awk '{print $0}')
  if [ -z "$flags" ] || ! echo "$flags" | grep -q ' lm '; then
    echo ""
    return
  fi
  local v1_required="cmov cx8 fpu fxsr mmx osfxsr sce sse sse2"
  local v2_required="cx16 lahf_lm popcnt sse3 sse4_1 sse4_2 ssse3"
  local v3_required="avx avx2 bmi1 bmi2 f16c fma lzcnt movbe osxsave"
  local check_flags
  check_flags() {
    local required="$1"
    for flag in $required; do
      if ! echo " $flags " | grep -q " $flag "; then
        return 1
      fi
    done
    return 0
  }
  if check_flags "$v1_required" && check_flags "$v2_required" && check_flags "$v3_required"; then
    echo "v3"
  elif check_flags "$v1_required" && check_flags "$v2_required"; then
    echo "v2"
  elif check_flags "$v1_required"; then
    echo "v1"
  else
    echo ""
  fi
}

detect_cpu_level_using_ld() {
  local ld_path="/lib64/ld-linux-x86-64.so.2"
  if [ ! -x "$ld_path" ]; then
    echo ""
    return 0
  fi
  local levels=$("$ld_path" --help 2>/dev/null | grep -oP 'x86-64-v\d+(?=.*\(supported, searched\))' | sort -u)
  if [ -z "$levels" ]; then
    echo ""
    return 0
  fi
  local highest_level=""
  for level in $levels; do
    case $level in
    x86-64-v3)
      highest_level="v3"
      break
      ;;
    x86-64-v2) highest_level="v2" ;;
    x86-64-v1) highest_level="v1" ;;
    x86-64-v4) highest_level="v3" ;;
    esac
  done
  echo "$highest_level"
  return 0
}

detect_cpu_level_using_sysctl() {
  # macOS: detect Apple Silicon vs Intel AVX2
  local brand=$(sysctl -n machdep.cpu.brand_string 2>/dev/null)
  if [[ "$brand" == *"Apple"* ]]; then
    echo ""
    return 0
  fi
  local features=$(sysctl -n machdep.cpu.features 2>/dev/null)
  if [ -n "$features" ] && echo "$features" | grep -qw "AVX2"; then
    echo "v3"
  else
    echo ""
  fi
}

detect_cpu_level() {
  if $IS_MACOS; then
    local level=$(detect_cpu_level_using_sysctl)
    if [ -n "$level" ]; then
      echo "-$level"
    else
      echo ""
    fi
    return 0
  fi
  local level=$(detect_cpu_level_using_ld)
  if [ -z "$level" ]; then
    level=$(detect_cpu_level_using_proc)
  fi
  if [ -n "$level" ]; then
    echo "-$level"
  else
    echo ""
  fi
}

# --- Core download helpers ---
download_mihomo() {
  local base_arch=$(detect_architecture)
  local arch=$([ "$base_arch" = "amd64" ] && echo "${base_arch}$(detect_cpu_level)" || echo "$base_arch")
  local os=$(detect_os)

  local temp_dir=$(mktemp -d)
  latest_version=$(curl -s "https://api.github.com/repos/${MIHOMO_UPSTREAM}/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
  local download_url

  if [ "$arch" = "unsupported" ] || [ "$os" = "unsupported" ]; then
    log_error "Unsupported architecture ($(uname -m)) or OS ($(uname -s))"
    rm -rf "$temp_dir"
    return 1
  fi

  download_url="https://github.com/${MIHOMO_UPSTREAM}/releases/latest/download/mihomo-${os}-${arch}-${latest_version}.gz"
  log_info "Detected: OS=$os, Arch=$arch, LatestVersion=$latest_version"
  log_info "Downloading: $download_url"

  curl -L "$download_url" -o "$temp_dir/mihomo.gz" || {
    log_error "Download failed"
    rm -rf "$temp_dir"
    return 1
  }
  gunzip -c "$temp_dir/mihomo.gz" >"$temp_dir/mihomo"

  local binary_path
  if [ -f "$temp_dir/mihomo" ]; then
    binary_path="$temp_dir/mihomo"
  else
    log_error "Could not find binary in the downloaded archive"
    rm -rf "$temp_dir"
    return 1
  fi

  $SUDO mkdir -p "$INSTALL_DIR_MIHOMO"
  $SUDO install -m 755 "$binary_path" "$INSTALL_DIR_MIHOMO/mihomo"
  log_info "Successfully installed mihomo to: $INSTALL_DIR_MIHOMO/mihomo"
  rm -rf "$temp_dir"
}

download_singbox() {
  local arch=$(detect_architecture)
  local os=$(detect_os)

  local temp_dir=$(mktemp -d)
  local tag_name
  tag_name=$(curl -s "https://api.github.com/repos/${SINGBOX_UPSTREAM}/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
  # sing-box asset names strip the 'v' prefix (v1.12.3 → 1.12.3)
  latest_version="${tag_name#v}"

  if [ "$arch" = "unsupported" ] || [ "$os" = "unsupported" ]; then
    log_error "Unsupported architecture ($(uname -m)) or OS ($(uname -s))"
    rm -rf "$temp_dir"
    return 1
  fi

  download_url="https://github.com/${SINGBOX_UPSTREAM}/releases/latest/download/sing-box-${latest_version}-${os}-${arch}.tar.gz"
  log_info "Detected: OS=$os, Arch=$arch, Version=$latest_version"
  log_info "Downloading: $download_url"

  curl -L "$download_url" -o "$temp_dir/sing-box.tar.gz" || {
    log_error "Download failed"
    rm -rf "$temp_dir"
    return 1
  }
  tar -xzf "$temp_dir/sing-box.tar.gz" -C "$temp_dir"

  local binary_path
  binary_path=$(find "$temp_dir" -name "sing-box" -type f | head -1)

  if [ -f "$binary_path" ]; then
    $SUDO mkdir -p "$INSTALL_DIR_SINGBOX"
    $SUDO install -m 755 "$binary_path" "$INSTALL_DIR_SINGBOX/sing-box"
    if ! $IS_USER; then
      $SUDO ln -sf "$INSTALL_DIR_SINGBOX/sing-box" /usr/bin/sing-box
    fi
    log_info "Successfully installed sing-box to: $INSTALL_DIR_SINGBOX/sing-box"
  else
    log_error "Could not find sing-box binary in the downloaded archive"
    rm -rf "$temp_dir"
    return 1
  fi

  rm -rf "$temp_dir"
}

download_clashtui() {
  local arch=$(detect_architecture)
  local os=$(detect_os)

  local temp_dir=$(mktemp -d)
  latest_version=$(curl -s "https://api.github.com/repos/${REPO}/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

  if [ "$arch" = "unsupported" ] || [ "$os" = "unsupported" ]; then
    log_error "Unsupported architecture ($(uname -m)) or OS ($(uname -s))"
    rm -rf "$temp_dir"
    return 1
  fi

  download_url="https://github.com/${REPO}/releases/latest/download/clashtui-${os}-${arch}-${latest_version}.gz"
  log_info "Detected: OS=$os, Arch=$arch, LatestVersion=$latest_version"
  log_info "Downloading: $download_url"

  curl -L "$download_url" -o "$temp_dir/clashtui.gz" || {
    log_error "Download failed"
    rm -rf "$temp_dir"
    return 1
  }
  gunzip -c "$temp_dir/clashtui.gz" >"$temp_dir/clashtui"

  local binary_path
  if [ -f "$temp_dir/clashtui" ]; then
    binary_path="$temp_dir/clashtui"
  else
    log_error "Could not find binary in the downloaded archive"
    rm -rf "$temp_dir"
    return 1
  fi

  $SUDO mkdir -p "$INSTALL_BIN"
  $SUDO install -m 755 "$binary_path" "$CLASHTUI_BIN"
  if ! $IS_USER; then
    $SUDO ln -sf "$CLASHTUI_BIN" /usr/local/bin/clashtui
  fi
  log_info "Successfully installed clashtui to: $CLASHTUI_BIN"
  rm -rf "$temp_dir"
}

# --- User/group creation (system mode only) ---
create_mihomo_user() {
  if $IS_USER || $IS_MACOS; then
    return 0
  fi
  if ! id "mihomo" &>/dev/null; then
    log_info "Creating mihomo user and group..."
    sudo groupadd --system mihomo
    sudo useradd --system --no-create-home --gid mihomo --shell /bin/false mihomo
  else
    log_info "mihomo user already exists"
  fi
}

create_singbox_user() {
  if $IS_USER || $IS_MACOS; then
    return 0
  fi
  if ! id "sing-box" &>/dev/null; then
    log_info "Creating sing-box user and group..."
    sudo groupadd --system sing-box
    sudo useradd --system --no-create-home --gid sing-box --shell /bin/false sing-box
  else
    log_info "sing-box user already exists"
  fi
}

# --- Service unit creation (systemd or launchd) ---
create_mihomo_unit() {
  local service_name="clashtui_mihomo"

  if $IS_MACOS; then
    # ── macOS: launchd plist ──
    local plist_path="$UNIT_DIR/${service_name}.plist"
    local log_dir
    $SUDO mkdir -p "$UNIT_DIR"
    if $IS_USER; then
      log_dir="$HOME/Library/Logs"
      mkdir -p "$log_dir"
    else
      log_dir="/usr/local/var/log"
      $SUDO mkdir -p "$log_dir"
    fi
    log_info "Creating mihomo launchd plist..."
    $SUDO tee "$plist_path" >/dev/null <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${service_name}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${INSTALL_DIR_MIHOMO}/mihomo</string>
        <string>-d</string>
        <string>${MIHOMO_CONFIG_DIR}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_dir}/${service_name}.log</string>
    <key>StandardErrorPath</key>
    <string>${log_dir}/${service_name}.log</string>
    <key>WorkingDirectory</key>
    <string>${MIHOMO_CONFIG_DIR}</string>
</dict>
</plist>
EOF
    log_info "Created launchd plist: $plist_path"
    if [ -n "$SERVICE_LOAD_CMD" ]; then
      $SERVICE_LOAD_CMD "$plist_path"
    fi
  elif [ "$SERVICE_CONTROLLER" = "openrc" ]; then
    # ── Linux: OpenRC init script ──
    log_info "Creating mihomo OpenRC init script..."
    local init_path="$UNIT_DIR/${service_name}"
    $SUDO tee "$init_path" >/dev/null <<EOF
#!/sbin/openrc-run

supervisor="supervise-daemon"
name="${service_name}"
description="mihomo Daemon, Another Clash Kernel."
command="${INSTALL_DIR_MIHOMO}/mihomo"
command_args="-d ${MIHOMO_CONFIG_DIR}"
EOF
    if ! $IS_USER; then
      $SUDO tee -a "$init_path" >/dev/null <<EOF
command_user="mihomo:mihomo"
pidfile="/run/\${RC_SVCNAME}.pid"
EOF
    fi
    $SUDO tee -a "$init_path" >/dev/null <<EOF

depend() {
    need net
}
EOF
    $SUDO chmod +x "$init_path"
    log_info "Created OpenRC init script: $init_path"
  else
    # ── Linux: systemd unit ──
    log_info "Creating mihomo systemd unit..."
    local unit_path

    if $IS_USER; then
      mkdir -p "$UNIT_DIR"
      unit_path="$UNIT_DIR/${service_name}.service"
      cat >"$unit_path" <<EOF
[Unit]
Description=mihomo Daemon, Another Clash Kernel.
After=network.target

[Service]
Type=simple
Restart=always
ExecStartPre=/usr/bin/sleep 1s
ExecStart=${INSTALL_DIR_MIHOMO}/mihomo -d ${MIHOMO_CONFIG_DIR}
ExecReload=/bin/kill -HUP \$MAINPID

[Install]
WantedBy=${UNIT_WANTED_BY}
EOF
      log_info "Created user unit: $unit_path"
    else
      $SUDO mkdir -p "$INSTALL_DIR_MIHOMO"
      unit_path="$INSTALL_DIR_MIHOMO/${service_name}.service"
      $SUDO tee "$unit_path" >/dev/null <<EOF
[Unit]
Description=mihomo Daemon, Another Clash Kernel.
After=network.target NetworkManager.service systemd-networkd.service iwd.service

[Service]
Type=simple
User=mihomo
Group=mihomo
LimitNPROC=500
LimitNOFILE=1000000
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_TIME CAP_SYS_PTRACE CAP_DAC_READ_SEARCH CAP_DAC_OVERRIDE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_TIME CAP_SYS_PTRACE CAP_DAC_READ_SEARCH CAP_DAC_OVERRIDE
Restart=always
ExecStartPre=/usr/bin/sleep 1s
ExecStart=${INSTALL_DIR_MIHOMO}/mihomo -d ${MIHOMO_CONFIG_DIR}
ExecReload=/bin/kill -HUP \$MAINPID

[Install]
WantedBy=${UNIT_WANTED_BY}
EOF
      $SUDO ln -sf "$unit_path" "$UNIT_DIR/"
    fi

    $SYSTEMD_RELOAD
  fi
}

create_singbox_unit() {
  local service_name="clashtui_singbox"

  if $IS_MACOS; then
    # ── macOS: launchd plist ──
    local plist_path="$UNIT_DIR/${service_name}.plist"
    local log_dir
    local singbox_bin="${INSTALL_DIR_SINGBOX}/sing-box"
    $SUDO mkdir -p "$UNIT_DIR"
    if $IS_USER; then
      log_dir="$HOME/Library/Logs"
      mkdir -p "$log_dir"
    else
      log_dir="/usr/local/var/log"
      $SUDO mkdir -p "$log_dir"
    fi
    log_info "Creating sing-box launchd plist..."
    $SUDO tee "$plist_path" >/dev/null <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${service_name}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${singbox_bin}</string>
        <string>-D</string>
        <string>${SINGBOX_CONFIG_DIR}</string>
        <string>-c</string>
        <string>${SINGBOX_CONFIG_DIR}/config.json</string>
        <string>run</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_dir}/${service_name}.log</string>
    <key>StandardErrorPath</key>
    <string>${log_dir}/${service_name}.log</string>
    <key>WorkingDirectory</key>
    <string>${SINGBOX_CONFIG_DIR}</string>
</dict>
</plist>
EOF
    log_info "Created launchd plist: $plist_path"
    if [ -n "$SERVICE_LOAD_CMD" ]; then
      $SERVICE_LOAD_CMD "$plist_path"
    fi
  elif [ "$SERVICE_CONTROLLER" = "openrc" ]; then
    # ── Linux: OpenRC init script ──
    log_info "Creating sing-box OpenRC init script..."
    local init_path="$UNIT_DIR/${service_name}"
    local singbox_cmd
    if $IS_USER; then
      singbox_cmd="${INSTALL_DIR_SINGBOX}/sing-box"
    else
      singbox_cmd="/usr/bin/sing-box"
    fi
    $SUDO tee "$init_path" >/dev/null <<EOF
#!/sbin/openrc-run

supervisor="supervise-daemon"
name="${service_name}"
description="sing-box Daemon, The universal proxy platform."
command="${singbox_cmd}"
command_args="-D ${SINGBOX_CONFIG_DIR} -c ${SINGBOX_CONFIG_DIR}/config.json run"
EOF
    if ! $IS_USER; then
      $SUDO tee -a "$init_path" >/dev/null <<EOF
command_user="sing-box:sing-box"
pidfile="/run/\${RC_SVCNAME}.pid"
EOF
    fi
    $SUDO tee -a "$init_path" >/dev/null <<EOF

depend() {
    need net
}
EOF
    $SUDO chmod +x "$init_path"
    log_info "Created OpenRC init script: $init_path"
  else
    # ── Linux: systemd unit ──
    log_info "Creating sing-box systemd unit..."
    local unit_path

    if $IS_USER; then
      mkdir -p "$UNIT_DIR"
      unit_path="$UNIT_DIR/${service_name}.service"
      cat >"$unit_path" <<EOF
[Unit]
Description=sing-box Daemon, The universal proxy platform.
After=network.target

[Service]
Type=simple
LimitNOFILE=infinity
Restart=on-failure
RestartSec=10s
ExecStartPre=/usr/bin/sleep 1s
ExecStart=/usr/bin/sing-box -D ${SINGBOX_CONFIG_DIR} -c ${SINGBOX_CONFIG_DIR}/config.json run
ExecReload=/bin/kill -HUP \$MAINPID

[Install]
WantedBy=${UNIT_WANTED_BY}
EOF
      # In user mode, sing-box binary is at INSTALL_DIR_SINGBOX rather than /usr/bin
      # So use that path directly
      sed -i "s|/usr/bin/sing-box|${INSTALL_DIR_SINGBOX}/sing-box|" "$unit_path"
      log_info "Created user unit: $unit_path"
    else
      $SUDO mkdir -p "$INSTALL_DIR_SINGBOX"
      unit_path="$INSTALL_DIR_SINGBOX/${service_name}.service"
      $SUDO tee "$unit_path" >/dev/null <<EOF
[Unit]
Description=sing-box Daemon, The universal proxy platform.
After=network.target NetworkManager.service systemd-networkd.service iwd.service

[Service]
Type=simple
User=sing-box
Group=sing-box
StateDirectory=sing-box
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_PTRACE CAP_DAC_READ_SEARCH
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_PTRACE CAP_DAC_READ_SEARCH
ExecStartPre=/usr/bin/sleep 1s
ExecStart=/usr/bin/sing-box -D ${SINGBOX_CONFIG_DIR} -c ${SINGBOX_CONFIG_DIR}/config.json run
ExecReload=/bin/kill -HUP \$MAINPID
Restart=on-failure
RestartSec=10s
LimitNOFILE=infinity

[Install]
WantedBy=${UNIT_WANTED_BY}
EOF
      $SUDO ln -sf "$unit_path" "$UNIT_DIR/"
    fi

    $SYSTEMD_RELOAD
  fi
}

# --- Core config creation ---
create_core_configs() {
  local core_type="$1"
  log_info "Creating core config files..."

  if [ "$core_type" = "mihomo" ] || [ "$core_type" = "all" ]; then
    backup_dir "$MIHOMO_CONFIG_DIR"
    backup_file "${MIHOMO_CONFIG_DIR}/config.yaml" || true
    $SUDO mkdir -p "$MIHOMO_CONFIG_DIR"

    local mihomo_cfg_src
    if $IS_USER; then
      mihomo_cfg_src="default_configs/mihomo/core_override_config_no_tun.yaml"
    else
      mihomo_cfg_src="default_configs/mihomo/core_override_config.yaml"
    fi

    # Copy core override config via contrib helper
    copy_contrib "$mihomo_cfg_src" "${MIHOMO_CONFIG_DIR}/config.yaml"
    log_info "Mihomo core config written to: ${MIHOMO_CONFIG_DIR}/config.yaml"

    # Also copy to clashtui config dir for profile management
    backup_dir "$MIHOMO_USER_CONFIG_DIR"
    mkdir -p "$MIHOMO_USER_CONFIG_DIR"
    copy_contrib "$mihomo_cfg_src" "${MIHOMO_USER_CONFIG_DIR}/core_override_config.yaml"
    log_info "Mihomo core override written to: ${MIHOMO_USER_CONFIG_DIR}/core_override_config.yaml"

    if ! $IS_USER; then
      if $IS_MACOS; then
        $SUDO chmod g+rw "${MIHOMO_CONFIG_DIR}/config.yaml"
      else
        $SUDO chown mihomo:mihomo "${MIHOMO_CONFIG_DIR}/config.yaml"
        $SUDO chmod g+r "${MIHOMO_CONFIG_DIR}/config.yaml"
      fi
    fi
  fi

  if [ ${#BACKED_UP_LIST[@]} -gt 0 ]; then
    echo ""
    log_info "Backups created:"
    for entry in "${BACKED_UP_LIST[@]}"; do
      echo "  $entry"
    done
  else
    echo ""
    log_info "No existing configs to backup"
  fi
}

# --- Clashtui user config generation ---
create_clashtui_config() {
  local core_type="$1"
  log_info "Creating clashtui config..."

  backup_dir "$CLASHTUI_CONFIG_DIR"
  mkdir -p "$CLASHTUI_CONFIG_DIR"

  # Copy contrib default_keymap.yaml and default_theme.yaml
  copy_contrib "default_configs/default_keymap.yaml" "$CLASHTUI_CONFIG_DIR/default_keymap.yaml"
  copy_contrib "default_configs/default_theme.yaml" "$CLASHTUI_CONFIG_DIR/default_theme.yaml"
  log_info "Copied default configs to: $CLASHTUI_CONFIG_DIR"

  # Generate single config.yaml with both core sections
  cat >"$CLASHTUI_CONFIG_DIR/config.yaml" <<EOF
mihomo:
  core:
    config_dir: ${MIHOMO_CONFIG_DIR}
    bin_path: ${INSTALL_DIR_MIHOMO}/mihomo
    config_path: ${MIHOMO_CONFIG_DIR}/config.yaml
  core_service:
    service_name: clashtui_mihomo
    is_user: ${SERVICE_IS_USER}
    service_controller: ${SERVICE_CONTROLLER}
singbox:
  core:
    bin_path: ${INSTALL_DIR_SINGBOX}/sing-box
    config_dir: ${SINGBOX_CONFIG_DIR}
    config_path: ${SINGBOX_CONFIG_DIR}/config.json
  core_service:
    service_name: clashtui_singbox
    is_user: ${SERVICE_IS_USER}
    service_controller: ${SERVICE_CONTROLLER}
timeout:
extra:
  edit_cmd:
  open_dir_cmd:
EOF

  log_info "Config written to: $CLASHTUI_CONFIG_DIR/config.yaml"

  # Generate per-core template_proxy_providers.yaml and directories
  if [ "$core_type" = "mihomo" ] || [ "$core_type" = "all" ]; then
    mkdir -p "$MIHOMO_USER_CONFIG_DIR"

    if [ ! -f "$MIHOMO_USER_CONFIG_DIR/template_proxy_providers.yaml" ]; then
      cat >"$MIHOMO_USER_CONFIG_DIR/template_proxy_providers.yaml" <<'EOF'
# Define proxy-provider subscription URLs here, organized by group.
# In templates use ${PPG.<group>} to reference all providers in a group,
# or ${PPG.<group>.<provider>} for a specific one.
#
# Format:
#   <group-name>:
#     <provider-name>: "<subscription-url>"
#
# Clashtui's built-in templates only use the group level
# (e.g. ${PPG.pvd}, not ${PPG.pvd.pvd0}). Provider names
# (pvd0, pvd1, ...) are freely defined by the user.
#
# Example (following clashtui convention):
#   pvd:
#     pvd0: "https://example.com/sub1.yaml"
#     pvd1: "https://example.com/sub2.yaml"
EOF
    fi
  fi

  if [ "$core_type" = "sing-box" ] || [ "$core_type" = "all" ]; then
    mkdir -p "$SINGBOX_USER_CONFIG_DIR"

    if [ ! -f "$SINGBOX_USER_CONFIG_DIR/template_proxy_providers.yaml" ]; then
      cat >"$SINGBOX_USER_CONFIG_DIR/template_proxy_providers.yaml" <<'EOF'
# Define proxy-provider subscription URLs here, organized by group.
# In templates use ${PPG.<group>} to reference all providers in a group,
# or ${PPG.<group>.<provider>} for a specific one.
#
# Format:
#   <group-name>:
#     <provider-name>: "<subscription-url>"
#
# Clashtui's built-in templates only use the group level
# (e.g. ${PPG.pvd}, not ${PPG.pvd.pvd0}). Provider names
# (pvd0, pvd1, ...) are freely defined by the user.
#
# Example (following clashtui convention):
#   pvd:
#     pvd0: "https://example.com/sub1.yaml"
#     pvd1: "https://example.com/sub2.yaml"
EOF
    fi
  fi

  # Create profiles and templates directories
  if [ "$core_type" = "mihomo" ] || [ "$core_type" = "all" ]; then
    mkdir -p "$MIHOMO_USER_CONFIG_DIR/profiles"
    mkdir -p "$MIHOMO_USER_CONFIG_DIR/templates"
  fi
  if [ "$core_type" = "sing-box" ] || [ "$core_type" = "all" ]; then
    mkdir -p "$SINGBOX_USER_CONFIG_DIR/profiles"
    mkdir -p "$SINGBOX_USER_CONFIG_DIR/templates"
  fi
}

# --- Optional downloads: templates and rules-dat ---
prompt_templates_and_rules() {
  local do_mihomo_tpl=false
  local do_rules_dat=false
  local do_singbox_tpl=false

  if $NO_PROMPT; then
    do_mihomo_tpl=true
    do_rules_dat=true
    do_singbox_tpl=true
  else
    if [ "$CORE_TYPE" = "mihomo" ] || [ "$CORE_TYPE" = "all" ]; then
      echo -n "Do you want to download templates for mihomo? (y/N): "
      read -r response
      if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
        do_mihomo_tpl=true
      fi

      echo -n "Do you want to download rules-dat? (y/N): "
      read -r response
      if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
        do_rules_dat=true
      fi
    fi

    if [ "$CORE_TYPE" = "sing-box" ] || [ "$CORE_TYPE" = "all" ]; then
      echo -n "Do you want to download templates for sing-box? (y/N): "
      read -r response
      if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
        do_singbox_tpl=true
      fi
    fi
  fi

  if $do_mihomo_tpl; then
    log_info "Downloading mihomo templates..."
    copy_contrib "templates/mihomo/common_tpl.yaml" "$MIHOMO_USER_CONFIG_DIR/templates/common_tpl.yaml"
    copy_contrib "templates/mihomo/generic_tpl.yaml" "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl.yaml"
    copy_contrib "templates/mihomo/generic_tpl_with_all.yaml" "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl_with_all.yaml"
    copy_contrib "templates/mihomo/generic_tpl_with_filter.yaml" "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl_with_filter.yaml"
    copy_contrib "templates/mihomo/generic_tpl_with_ruleset.yaml" "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl_with_ruleset.yaml"
  fi

  if $do_rules_dat; then
    log_info "Downloading rules-dat..."
    curl -Lo "${MIHOMO_CONFIG_DIR}/geoip.metadb" "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.metadb"
    curl -Lo "${MIHOMO_CONFIG_DIR}/GeoSite.dat" "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat"
  fi

  if $do_singbox_tpl; then
    log_info "Downloading sing-box templates..."
    copy_contrib "templates/sing-box/v1.12-tun_common_tpl.json" "$SINGBOX_USER_CONFIG_DIR/templates/v1.12-tun_common_tpl.json"
  fi
}

# --- Install core ---
install_mihomo() {
  if command_exists mihomo; then
    $SUDO mkdir -p "$INSTALL_DIR_MIHOMO"
    $SUDO ln -sf "$(which mihomo)" "$INSTALL_DIR_MIHOMO/mihomo"
  elif command_exists clash-meta; then
    $SUDO mkdir -p "$INSTALL_DIR_MIHOMO"
    $SUDO ln -sf "$(which clash-meta)" "$INSTALL_DIR_MIHOMO/mihomo"
  else
    download_mihomo
  fi

  create_mihomo_user

  if ! $IS_USER; then
    if $IS_MACOS; then
      # macOS: service runs as root, admin group gets r/w access
      $SUDO chown -R root:admin "$INSTALL_DIR_MIHOMO"
      $SUDO chmod g+rwxs "$MIHOMO_CONFIG_DIR"
    else
      sudo gpasswd -a "$USER" mihomo
      $SUDO chown -R mihomo:mihomo "$INSTALL_DIR_MIHOMO"
      $SUDO chmod g+rwxs "$MIHOMO_CONFIG_DIR"
    fi
  fi

  create_mihomo_unit
}

install_singbox() {
  if command_exists sing-box; then
    $SUDO mkdir -p "$INSTALL_DIR_SINGBOX"
    $SUDO ln -sf "$(which sing-box)" "$INSTALL_DIR_SINGBOX/sing-box"
    if ! $IS_USER && ! $IS_MACOS; then
      $SUDO ln -sf "$INSTALL_DIR_SINGBOX/sing-box" /usr/bin/sing-box
    fi
  else
    download_singbox
  fi

  create_singbox_user

  if ! $IS_USER; then
    if $IS_MACOS; then
      $SUDO chown -R root:admin "$INSTALL_DIR_SINGBOX"
      $SUDO chmod g+rwxs "$SINGBOX_CONFIG_DIR"
    else
      sudo gpasswd -a "$USER" sing-box
      $SUDO chown -R sing-box:sing-box "$INSTALL_DIR_SINGBOX"
      $SUDO chmod g+rwxs "$SINGBOX_CONFIG_DIR"
    fi
  fi

  create_singbox_unit
}

install_clashtui() {
  local core_type="$1"
  if command_exists clashtui; then
    $SUDO mkdir -p "$INSTALL_BIN"
    $SUDO ln -sf "$(which clashtui)" "$CLASHTUI_BIN"
  else
    download_clashtui
  fi

  create_clashtui_config "$core_type"
}

# --- Uninstall ---
uninstall() {
  echo "Please make sure the mihomo and sing-box daemons have been stopped before uninstallation."
  echo -n "Continue with uninstallation? (y/N): "
  read -r response
  if [ "$response" != "y" ] && [ "$response" != "Y" ]; then
    echo "Uninstallation cancelled."
    return 1
  fi

  rm -rf ~/.cache/clashtui
  if $IS_USER; then
    if $IS_MACOS; then
      launchctl unload "$UNIT_DIR/clashtui_mihomo.plist" 2>/dev/null
      launchctl unload "$UNIT_DIR/clashtui_singbox.plist" 2>/dev/null
      rm -f "$UNIT_DIR/clashtui_mihomo.plist"
      rm -f "$UNIT_DIR/clashtui_singbox.plist"
    else
      if [ "$SERVICE_CONTROLLER" = "openrc" ]; then
        rc-service --user clashtui_mihomo stop 2>/dev/null
        rc-service --user clashtui_singbox stop 2>/dev/null
        rc-update --user del clashtui_mihomo default 2>/dev/null
        rc-update --user del clashtui_singbox default 2>/dev/null
        sudo rm -f "$UNIT_DIR/clashtui_mihomo"
        sudo rm -f "$UNIT_DIR/clashtui_singbox"
      else
        rm -f "$UNIT_DIR/clashtui_mihomo.service"
        rm -f "$UNIT_DIR/clashtui_singbox.service"
        systemctl --user daemon-reload
      fi
    fi
    rm -rf "$INSTALL_DIR"
  else
    if $IS_MACOS; then
      sudo launchctl unload "$UNIT_DIR/clashtui_mihomo.plist" 2>/dev/null
      sudo launchctl unload "$UNIT_DIR/clashtui_singbox.plist" 2>/dev/null
      sudo rm -f "$UNIT_DIR/clashtui_mihomo.plist"
      sudo rm -f "$UNIT_DIR/clashtui_singbox.plist"
      sudo rm -rf "$INSTALL_DIR"
      echo "[Optional] Remove log files"
      echo "  sudo rm -f /usr/local/var/log/clashtui_mihomo.log"
      echo "  sudo rm -f /usr/local/var/log/clashtui_singbox.log"
    else
      if [ "$SERVICE_CONTROLLER" = "openrc" ]; then
        sudo rc-service clashtui_mihomo stop 2>/dev/null
        sudo rc-service clashtui_singbox stop 2>/dev/null
        sudo rc-update del clashtui_mihomo default 2>/dev/null
        sudo rc-update del clashtui_singbox default 2>/dev/null
        sudo rm -f /etc/init.d/clashtui_mihomo
        sudo rm -f /etc/init.d/clashtui_singbox
      else
        sudo rm -f /usr/lib/systemd/system/clashtui_mihomo.service
        sudo rm -f /usr/lib/systemd/system/clashtui_singbox.service
        sudo systemctl daemon-reload
      fi
      sudo rm -rf /opt/clashtui

      echo "[Optional] Delete the mihomo user and group"
      echo "  sudo gpasswd -d $USER mihomo"
      echo "  sudo userdel mihomo"
      echo "[Optional] Delete the sing-box user and group"
      echo "  sudo gpasswd -d $USER sing-box"
      echo "  sudo userdel sing-box"
    fi
  fi

  log_info "Uninstallation complete."
}

# --- Help ---
show_help() {
  echo "Usage: $0 [OPTION]"
  echo "Install or uninstall clashtui"
  echo
  echo "Options:"
  echo "  -h, --help       Show this help message and exit"
  echo "  -u, --uninstall  Uninstall clashtui"
  echo "  --is-user        Install to ~/.local/clashtui (user mode, no root required)"
  echo "  --repo <R>       GitHub repo for clashtui and contrib (default: $REPO)"
  echo "  --branch <B>     Branch for contrib resources (default: $BRANCH)"
  echo "  --core <TYPE>    Select core: mihomo, sing-box, or all (default: all)"
  echo "  --service-controller <CTRL>  Init system: systemd or openrc (default: systemd)"
  echo "  --no-prompt                   Skip interactive prompts and download everything (default: no)"
  echo
  echo "When --is-user is set:"
  echo "  - Installs to ~/.local/clashtui"
  if $IS_MACOS; then
    echo "  - Uses user-scoped launchd plists (~/Library/LaunchAgents)"
  else
    echo "  - Uses user-scoped units (systemctl --user or /etc/user/init.d for openrc)"
  fi
  echo "  - Uses no-TUN core configs (TUN requires root capabilities)"
  echo "  - Skips creating system users/groups"
  echo
  echo "When --service-controller openrc is set on Linux:"
  echo "  - System mode: creates OpenRC init scripts in /etc/init.d/"
  echo "  - User mode:   creates OpenRC init scripts in /etc/user/init.d/"
  echo "  - User mode requires XDG_RUNTIME_DIR (e.g. via elogind or shell rc)"
  echo
  echo "If no options are provided, the script will install clashtui with all cores"
  if $IS_MACOS; then
    echo "to /usr/local/opt/clashtui (system mode)."
  else
    echo "to /opt/clashtui (system mode)."
  fi
}

# --- Main ---
main() {
  while [[ $# -gt 0 ]]; do
    case $1 in
    -u | --uninstall)
      resolve_paths
      uninstall
      return 0
      ;;
    -h | --help)
      show_help
      return 0
      ;;
    --is-user)
      IS_USER=true
      ;;
    --repo)
      if [ -z "$2" ]; then
        log_error "--repo requires a value (e.g., owner/repo)"
        exit 1
      fi
      REPO="$2"
      shift
      ;;
    --branch)
      if [ -z "$2" ]; then
        log_error "--branch requires a value"
        exit 1
      fi
      BRANCH="$2"
      shift
      ;;
    --core)
      if [ -z "$2" ]; then
        log_error "--core requires a value: mihomo, sing-box, or all"
        exit 1
      fi
      case "$2" in
      mihomo | sing-box | all)
        CORE_TYPE="$2"
        shift
        ;;
      *)
        log_error "Invalid core type: $2. Valid values: mihomo, sing-box, all"
        exit 1
        ;;
      esac
      ;;
    --service-controller)
      if [ -z "$2" ]; then
        log_error "--service-controller requires a value: systemd or openrc"
        exit 1
      fi
      case "$2" in
      systemd | openrc)
        SERVICE_CONTROLLER="$2"
        shift
        ;;
      *)
        log_error "Invalid service controller: $2. Valid values: systemd, openrc"
        exit 1
        ;;
      esac
      ;;
    --no-prompt)
      NO_PROMPT=true
      ;;
    *)
      log_error "Unknown option: $1"
      show_help
      return 1
      ;;
    esac
    shift
  done

  # Resolve all paths based on parsed options
  resolve_paths

  log_info "Install mode: $([ "$IS_USER" = "true" ] && echo "user (~/.local/clashtui)" || echo "system ($INSTALL_DIR)")"
  log_info "Core type: $CORE_TYPE"
  log_info "Repo: $REPO"
  log_info "Branch: $BRANCH"
  log_info "OS: $(detect_os)"

  # Create necessary directories
  if [ "$CORE_TYPE" = "mihomo" ] || [ "$CORE_TYPE" = "all" ]; then
    $SUDO mkdir -p "$MIHOMO_CONFIG_DIR"
  fi
  if [ "$CORE_TYPE" = "sing-box" ] || [ "$CORE_TYPE" = "all" ]; then
    $SUDO mkdir -p "$SINGBOX_CONFIG_DIR"
  fi
  mkdir -p "$CLASHTUI_CONFIG_DIR"

  # Install cores
  case "$CORE_TYPE" in
  mihomo)
    install_mihomo
    ;;
  sing-box)
    install_singbox
    ;;
  all)
    install_mihomo
    install_singbox
    ;;
  esac

  # Install clashtui (binary + config)
  install_clashtui "$CORE_TYPE"

  # Create core configs (no-TUN when is-user)
  create_core_configs "$CORE_TYPE"

  # Optional downloads
  prompt_templates_and_rules

  log_info "Installed cores: $CORE_TYPE"

  if $IS_USER; then
    if $IS_MACOS; then
      log_info "User mode: plist files created in ~/Library/LaunchAgents/"
      log_info "Services are NOT started automatically. Use these commands:"
      log_info "  Start now:         launchctl load ~/Library/LaunchAgents/clashtui_mihomo.plist"
      log_info "  Start + autostart: launchctl load -w ~/Library/LaunchAgents/clashtui_mihomo.plist"
      log_info "  Stop + disable:    launchctl unload ~/Library/LaunchAgents/clashtui_mihomo.plist"
      log_warn "Services will stop when you log out. To keep them running, keep the session active."
    else
      if [ "$SERVICE_CONTROLLER" = "openrc" ]; then
        log_info "User mode (OpenRC): init scripts created in /etc/user/init.d/"
        log_info "Services are NOT started automatically. Use these commands:"
        log_info "  Start now:         rc-service --user clashtui_mihomo start"
        log_info "  Start + autostart: rc-update --user add clashtui_mihomo default && rc-service --user clashtui_mihomo start"
        log_info "  Stop:              rc-service --user clashtui_mihomo stop"
        log_info "  Disable autostart: rc-update --user del clashtui_mihomo default"
        log_warn "OpenRC user services require XDG_RUNTIME_DIR to be set (e.g. via elogind or shell rc)"
      else
        log_info "User mode: unit files created in ~/.config/systemd/user/"
        log_info "Services are NOT started automatically. Use these commands:"
        log_info "  Start now:         systemctl --user start clashtui_mihomo"
        log_info "  Start + autostart: systemctl --user enable --now clashtui_mihomo"
        log_warn "To keep services running after logout, run: loginctl enable-linger"
      fi
    fi
  else
    if $IS_MACOS; then
      log_info "System mode: plist files created in /Library/LaunchDaemons/"
      log_info "Services are NOT started automatically. Use these commands:"
      log_info "  Start now:         sudo launchctl load /Library/LaunchDaemons/clashtui_mihomo.plist"
      log_info "  Start + autostart: sudo launchctl load -w /Library/LaunchDaemons/clashtui_mihomo.plist"
      log_info "  Stop + disable:    sudo launchctl unload /Library/LaunchDaemons/clashtui_mihomo.plist"
    else
      if [ "$SERVICE_CONTROLLER" = "openrc" ]; then
        log_info "System mode (OpenRC): init scripts created in /etc/init.d/"
        log_info "Services are NOT started automatically. Use these commands:"
        log_info "  Start now:         sudo rc-service clashtui_mihomo start"
        log_info "  Start + autostart: sudo rc-update add clashtui_mihomo default && sudo rc-service clashtui_mihomo start"
        log_info "  Stop:              sudo rc-service clashtui_mihomo stop"
        log_info "  Disable autostart: sudo rc-update del clashtui_mihomo default"
      else
        log_info "System mode: unit files created in /usr/lib/systemd/system/"
        log_info "Services are NOT started automatically. Use these commands:"
        log_info "  Start now:         sudo systemctl start clashtui_mihomo"
        log_info "  Start + autostart: sudo systemctl enable --now clashtui_mihomo"
      fi
    fi
  fi
}

# Only execute main when run directly (not sourced)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
