{
  "log": {
    "disabled": false,
    "level": "error",
    "timestamp": true
  },
  "dns": {
    "rules": [
      {
        "clash_mode": "Proxy",
        "server": "remote"
      },
      {
        "clash_mode": "Direct",
        "server": "local"
      },
      {
        "rule_set": [
          "geosite-geolocation-cn"
        ],
        "server": "local"
      },
      {
        "rule_set": [
          "geosite-geolocation-!cn"
        ],
        "server": "remote"
      },
      {
        "rule_set": [
          "category-ads-all"
        ],
        "server": "block"
      }
    ],
    "servers": [
      {
        "detour": "Entry",
        "type": "tls",
        "server": "8.8.8.8",
        "tag": "remote"
      },
      {
        "tag": "local",
        "type": "https",
        "server": "223.5.5.5"
      },
      {
        "type": "hosts",
        "path": [],
        "predefined": {},
        "tag": "block"
      }
    ],
    "strategy": "prefer_ipv4"
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "default_mode": "Rule",
      "external_controller": "127.0.0.1:9090",
      "external_ui": "dashboard",
      "secret": ""
    }
  },
  "inbounds": [
    {
      "address": [
        "172.18.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "type": "tun"
    },
    {
      "listen": "127.0.0.1",
      "listen_port": 2080,
      "tag": "mixed-in",
      "type": "mixed",
      "users": []
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Entry",
      "outbounds": [
        "${PGG.Auto}",
        "${PGG.Select}"
      ]
    },
    {
      "type": "selector",
      "tag": "Select",
      "expand_group_with": [
        "${PPG.pvd}"
      ]
    },
    {
      "type": "urltest",
      "tag": "Auto",
      "expand_group_with": [
        "${PPG.pvd}"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local",
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "Proxy",
        "outbound": "Entry"
      },
      {
        "rule_set": [
          "geosite-geolocation-!cn"
        ],
        "outbound": "Entry"
      },
      {
        "rule_set": [
          "geosite-geolocation-cn"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geoip-cn"
        ],
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": [
          "category-ads-all"
        ],
        "action": "reject"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-geolocation-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs"
      },
      {
        "type": "remote",
        "tag": "geosite-geolocation-!cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs"
      },
      {
        "type": "remote",
        "tag": "category-ads-all",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs"
      }
    ]
  }
}
