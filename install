#!/usr/bin/env bash

CLASHTUI_CONFIG_DIR=${XDG_CONFIG_HOME:-$HOME/.config}/clashtui
MIHOMO_USER_CONFIG_DIR=${CLASHTUI_CONFIG_DIR}/mihomo
SINGBOX_USER_CONFIG_DIR=${CLASHTUI_CONFIG_DIR}/sing-box
CLASHTUI_INSTALL_DIR=/opt/clashtui
MIHOMO_CONFIG_DIR=${CLASHTUI_INSTALL_DIR}/mihomo/config
SINGBOX_CONFIG_DIR=${CLASHTUI_INSTALL_DIR}/sing-box/config
INSTALL_RES_URL_PREFIX=https://raw.githubusercontent.com/JohanChane/clashtui/refs/heads/main/InstallRes

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
  echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $1" >&2
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

backup_file() {
    [ -e "$1" ] || return 1
    local i=1
    while [ -e "${1}_$i" ]; do
        ((i++))
    done
    mv "$1" "${1}_$i"
}

create_mihomo_user() {
  if ! id "mihomo" &>/dev/null; then
    log_info "Creating mihomo user and group..."
    sudo groupadd --system mihomo
    sudo useradd --system --no-create-home --gid mihomo --shell /bin/false mihomo
  else
    log_info "mihomo user already exists"
  fi
}

create_mihomo_systemd_unit() {
  log_info "Creating mihomo systemd unit..."

  sudo mkdir -p "$CLASHTUI_INSTALL_DIR/mihomo"
  sudo tee "$CLASHTUI_INSTALL_DIR/mihomo/clashtui_mihomo.service" >/dev/null <<'EOF'
[Unit]
Description=mihomo Daemon, Another Clash Kernel.
After=network.target NetworkManager.service systemd-networkd.service iwd.service

[Service]
Type=simple
User=mihomo
Group=mihomo
LimitNPROC=500
LimitNOFILE=1000000
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_TIME CAP_SYS_PTRACE CAP_DAC_READ_SEARCH CAP_DAC_OVERRIDE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_TIME CAP_SYS_PTRACE CAP_DAC_READ_SEARCH CAP_DAC_OVERRIDE
Restart=always
ExecStartPre=/usr/bin/sleep 1s
ExecStart=/opt/clashtui/mihomo/mihomo -d /opt/clashtui/mihomo/config
ExecReload=/bin/kill -HUP $MAINPID

[Install]
WantedBy=multi-user.target
EOF

  sudo ln -sf $CLASHTUI_INSTALL_DIR/mihomo/clashtui_mihomo.service /etc/systemd/system/
  sudo systemctl daemon-reload
}

create_singbox_user() {
  if ! id "sing-box" &>/dev/null; then
    log_info "Creating sing-box user and group..."
    sudo groupadd --system sing-box
    sudo useradd --system --no-create-home --gid sing-box --shell /bin/false sing-box
  else
    log_info "sing-box user already exists"
  fi
}

create_singbox_systemd_unit() {
  log_info "Creating singbox systemd unit..."

  sudo mkdir -p "$CLASHTUI_INSTALL_DIR/sing-box"
  sudo tee "$CLASHTUI_INSTALL_DIR/sing-box/clashtui_singbox.service" >/dev/null <<'EOF'
[Unit]
Description=sing-box Daemon, The universal proxy platform.
After=network.target NetworkManager.service systemd-networkd.service iwd.service

[Service]
Type=simple
User=sing-box
Group=sing-box
StateDirectory=sing-box
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_PTRACE CAP_DAC_READ_SEARCH
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE CAP_SYS_PTRACE CAP_DAC_READ_SEARCH
ExecStartPre=/usr/bin/sleep 1s
ExecStart=/usr/bin/sing-box -D /opt/clashtui/sing-box/config -c /opt/clashtui/sing-box/config/config.json run
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=10s
LimitNOFILE=infinity

[Install]
WantedBy=multi-user.target
EOF

  sudo ln -sf $CLASHTUI_INSTALL_DIR/sing-box/clashtui_singbox.service /etc/systemd/system/
  sudo systemctl daemon-reload
}

create_clashtui_config() {
  local core_type="$1"
  log_info "Creating clashtui config..."

  case "$core_type" in
  mihomo)
    mkdir -p "$MIHOMO_USER_CONFIG_DIR"

    # backup config.yaml
    backup_file "$MIHOMO_USER_CONFIG_DIR/config.yaml"

    tee "$MIHOMO_USER_CONFIG_DIR/config.yaml" >/dev/null <<'EOF'
core-type: mihomo
basic:
  clash_config_dir: '/opt/clashtui/mihomo/config'
  clash_bin_path: '/opt/clashtui/mihomo/mihomo'
  clash_config_path: '/opt/clashtui/mihomo/config/config.yaml'
  timeout: null
service:
  clash_srv_name: 'clashtui_mihomo'
  is_user: false
extra:
  edit_cmd:
  open_dir_cmd:
EOF
    ;;
  sing-box)
    mkdir -p "$SINGBOX_USER_CONFIG_DIR"

    # backup config.yaml
    backup_file "$SINGBOX_USER_CONFIG_DIR/config.yaml"

    tee "$SINGBOX_USER_CONFIG_DIR/config.yaml" >/dev/null <<'EOF'
core-type: sing-box
singbox:
  singbox_bin_path: '/opt/clashtui/sing-box/sing-box'
  singbox_config_dir: '/opt/clashtui/sing-box/config'
  singbox_config_path: '/opt/clashtui/sing-box/config/config.json'
service:
  singbox_srv_name: 'clashtui_singbox'
  is_user: false
extra:
  edit_cmd:
  open_dir_cmd:
EOF
    ;;
  all)
    mkdir -p "$MIHOMO_USER_CONFIG_DIR"
    mkdir -p "$SINGBOX_USER_CONFIG_DIR"

    # backup config.yaml for both cores
    backup_file "$MIHOMO_USER_CONFIG_DIR/config.yaml"
    backup_file "$SINGBOX_USER_CONFIG_DIR/config.yaml"

    tee "$MIHOMO_USER_CONFIG_DIR/config.yaml" >/dev/null <<'EOF'
core-type: mihomo
basic:
  clash_config_dir: '/opt/clashtui/mihomo/config'
  clash_bin_path: '/opt/clashtui/mihomo/mihomo'
  clash_config_path: '/opt/clashtui/mihomo/config/config.yaml'
  timeout: null
service:
  clash_srv_name: 'clashtui_mihomo'
  is_user: false
extra:
  edit_cmd:
  open_dir_cmd:
EOF

    tee "$SINGBOX_USER_CONFIG_DIR/config.yaml" >/dev/null <<'EOF'
core-type: sing-box
singbox:
  singbox_bin_path: '/opt/clashtui/sing-box/sing-box'
  singbox_config_dir: '/opt/clashtui/sing-box/config'
  singbox_config_path: '/opt/clashtui/sing-box/config/config.json'
service:
  singbox_srv_name: 'clashtui_singbox'
  is_user: false
extra:
  edit_cmd:
  open_dir_cmd:
EOF
    ;;
  esac

  if [ "$core_type" = "mihomo" ] || [ "$core_type" = "all" ]; then
    echo -n "Do you want to download basic_clash_config.yaml? (y/N): "
    read -r response
    if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
      backup_file "$MIHOMO_USER_CONFIG_DIR/basic_clash_config.yaml"

      log_info "Downloading basic_clash_config.yaml..."
      curl -o "$MIHOMO_USER_CONFIG_DIR/basic_clash_config.yaml" $INSTALL_RES_URL_PREFIX/basic_clash_config.yaml
    elif [ ! -f "$MIHOMO_USER_CONFIG_DIR/basic_clash_config.yaml" ]; then
      tee "$MIHOMO_USER_CONFIG_DIR/basic_clash_config.yaml" >/dev/null <<'EOF'
mixed-port: 7890
mode: rule
log-level: info
external-controller: 127.0.0.1:9090
EOF
    fi

    sudo mkdir -p "$MIHOMO_CONFIG_DIR"
    sudo cp "$MIHOMO_USER_CONFIG_DIR/basic_clash_config.yaml" "${MIHOMO_CONFIG_DIR}/config.yaml"
  fi

  if [ "$core_type" = "sing-box" ] || [ "$core_type" = "all" ]; then
    create_singbox_config
  fi

  if [ "$core_type" = "mihomo" ] || [ "$core_type" = "all" ]; then
    mkdir -p "$MIHOMO_USER_CONFIG_DIR/profile_yamls"
    mkdir -p "$MIHOMO_USER_CONFIG_DIR/templates"
    local mihomo_template_proxy_providers_path
    mihomo_template_proxy_providers_path="$MIHOMO_USER_CONFIG_DIR/templates/template_proxy_providers"
    if [ ! -f "$mihomo_template_proxy_providers_path" ]; then
      tee "$mihomo_template_proxy_providers_path" >/dev/null <<'EOF'
# This is a comment
# Place each subscription on a separate line
EOF
    fi

    echo -n "Do you want to download templates for mihomo? (y/N): "
    read -r response
    if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
      log_info "Downloading mihomo templates..."
      curl -o "$MIHOMO_USER_CONFIG_DIR/templates/common_tpl.yaml" $INSTALL_RES_URL_PREFIX/templates/common_tpl.yaml
      curl -o "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl.yaml" $INSTALL_RES_URL_PREFIX/templates/generic_tpl.yaml
      curl -o "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl_with_all.yaml" $INSTALL_RES_URL_PREFIX/templates/generic_tpl_with_all.yaml
      curl -o "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl_with_filter.yaml" $INSTALL_RES_URL_PREFIX/templates/generic_tpl_with_filter.yaml
      curl -o "$MIHOMO_USER_CONFIG_DIR/templates/generic_tpl_with_rulest.yaml" $INSTALL_RES_URL_PREFIX/templates/generic_tpl_with_ruleset.yaml
    fi

    echo -n "Do you want to download rules-dat? (y/N): "
    read -r response
    if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
      log_info "Downloading rules-dat..."
      curl -Lo  "${MIHOMO_CONFIG_DIR}/geoip.metadb" "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.metadb"
      curl -Lo  "${MIHOMO_CONFIG_DIR}/GeoSite.dat" "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat"
    fi
  fi

  if [ "$core_type" = "sing-box" ] || [ "$core_type" = "all" ]; then
    mkdir -p "$SINGBOX_USER_CONFIG_DIR/profile_jsons"
    mkdir -p "$SINGBOX_USER_CONFIG_DIR/templates"
    local singbox_template_proxy_providers_path
    singbox_template_proxy_providers_path="$SINGBOX_USER_CONFIG_DIR/templates/template_proxy_providers"
    if [ ! -f "$singbox_template_proxy_providers_path" ]; then
      tee "$singbox_template_proxy_providers_path" >/dev/null <<'EOF'
# Proxy-provider is not supported in sing-box.
# This template is a placeholder for future use.
EOF
    fi
  fi
}

detect_architecture() {
  local arch
  arch=$(uname -m)

  case "$arch" in
  x86_64 | amd64)
    echo "amd64"
    ;;
  aarch64 | arm64)
    echo "arm64"
    ;;
  armv7l | armhf)
    echo "armv7"
    ;;
  armv6l)
    echo "armv6"
    ;;
  i386 | i686)
    echo "386"
    ;;
  *)
    echo "unsupported"
    ;;
  esac
}

detect_os() {
  local os
  os=$(uname -s | tr '[:upper:]' '[:lower:]')

  case "$os" in
  linux)
    echo "linux"
    ;;
  darwin)
    echo "darwin"
    ;;
  freebsd)
    echo "freebsd"
    ;;
  *)
    echo "unsupported"
    ;;
  esac
}

# Detect CPU instruction set level using /proc/cpuinfo (mask v4, maximum to v3)
detect_cpu_level_using_proc() {
  # Get CPU instruction set (flags field) from /proc/cpuinfo
  local flags=$(grep -m 1 '^flags' /proc/cpuinfo | awk '{print $0}')

  # Check if it's amd64 (x86-64) architecture (basic requirement)
  if ! echo "$flags" | grep -q ' lm '; then
    echo "" # Non-amd64 architecture, output empty
    return
  fi

  # Define instruction sets required for each level (maximum to v3)
  # x86-64-v1 basic instruction set
  local v1_required="cmov cx8 fpu fxsr mmx osfxsr sce sse sse2"
  # x86-64-v2 extended instruction set (based on v1)
  local v2_required="cx16 lahf_lm popcnt sse3 sse4_1 sse4_2 ssse3"
  # x86-64-v3 advanced instruction set (based on v2)
  local v3_required="avx avx2 bmi1 bmi2 f16c fma lzcnt movbe osxsave"
  # x86-64-v4 flagship instruction set (based on v3)
  local v4_required="avx512f avx512bw avx512cd avx512dq avx512vl"

  # Check if all instruction sets are satisfied
  local check_flags
  check_flags() {
    local required="$1"
    for flag in $required; do
      # Exact match instruction set (with spaces before and after to avoid partial matches)
      if ! echo " $flags " | grep -q " $flag "; then
        return 1
      fi
    done
    return 0
  }

  # Determine from highest level (v3 -> v2 -> v1)
  # if check_flags "$v1_required" && check_flags "$v2_required" && check_flags "$v3_required" && check_flags "$v4_required"; then
  #     echo "v4"
  # el
  if check_flags "$v1_required" && check_flags "$v2_required" && check_flags "$v3_required"; then
    echo "v3"
  elif check_flags "$v1_required" && check_flags "$v2_required"; then
    echo "v2"
  elif check_flags "$v1_required"; then
    echo "v1"
  else
    echo "" # Does not meet v1 basic requirements, output empty
  fi
}

# Detect CPU instruction set level using dynamic linker (mask v4, maximum to v3)
detect_cpu_level_using_ld() {
  local ld_path="/lib64/ld-linux-x86-64.so.2"

  # Check if the dynamic linker exists and is executable (may not exist on non-amd64 architectures)
  if [ ! -x "$ld_path" ]; then
    echo "" # Non-amd64 architecture, output empty
    return 0
  fi

  # Get levels marked with "(supported, searched)" in the dynamic linker help information
  local levels=$("$ld_path" --help 2>/dev/null | grep -oP 'x86-64-v\d+(?=.*\(supported, searched\))' | sort -u)

  # Return empty if no supported level information is found
  if [ -z "$levels" ]; then
    echo ""
    return 0
  fi

  # Find the highest supported level (maximum to v3)
  local highest_level=""
  for level in $levels; do
    case $level in
    x86-64-v3)
      highest_level="v3"
      break
      ;; # Highest level is v3
    x86-64-v2) highest_level="v2" ;;
    x86-64-v1) highest_level="v1" ;;
    x86-64-v4) highest_level="v3" ;; # Mask v4, treat as v3
    esac
  done

  echo "$highest_level"
  return 0
}

# Main function: Handle output format
detect_cpu_level() {
  # First try using the dynamic linker method
  local level=$(detect_cpu_level_using_ld)

  # Use proc method if dynamic linker method returns empty
  if [ -z "$level" ]; then
    level=$(detect_cpu_level_using_proc)
  fi

  # Handle output format: output empty if empty, add prefix - if there is a value
  if [ -n "$level" ]; then
    echo "-$level"
  else
    echo ""
  fi
}

download_mihomo() {
  # First get the base architecture value
  local base_arch=$(detect_architecture)
  # When the base architecture is amd64, concatenate the cpu_level value; otherwise, use the base architecture value directly
  local arch=$([ "$base_arch" = "amd64" ] && echo "${base_arch}$(detect_cpu_level)" || echo "$base_arch")
  local os=$(detect_os)
  local download_url
  local temp_dir=$(mktemp -d)
  local latest_version=$(curl -s "https://api.github.com/repos/MetaCubeX/mihomo/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

  if [ "$arch" = "unsupported" ] || [ "$os" = "unsupported" ]; then
    log_error "Unsupported architecture ($(uname -m)) or OS ($(uname -s))"
    rm -rf "$temp_dir"
    return 1
  fi

  download_url="https://github.com/MetaCubeX/mihomo/releases/latest/download/mihomo-${os}-${arch}-${latest_version}.gz"

  log_info "Detected: OS=$os, Arch=$arch, LatestVersion=$latest_version, download_url=$download_url"

  curl -L "$download_url" -o "$temp_dir/mihomo.gz"
  gunzip -c "$temp_dir/mihomo.gz" >"$temp_dir/mihomo"

  local binary_path
  if [ -f "$temp_dir/mihomo" ]; then
    binary_path="$temp_dir/mihomo"
  else
    log_error "Could not find binary in the downloaded archive"
    rm -rf "$temp_dir"
    return 1
  fi

  sudo mkdir -p "$CLASHTUI_INSTALL_DIR/mihomo"
  sudo install -m 755 "$binary_path" "$CLASHTUI_INSTALL_DIR/mihomo/mihomo"
  log_info "Successfully installed mihomo to: $CLASHTUI_INSTALL_DIR/mihomo/mihomo"
  rm -rf "$temp_dir"
}

install_mihomo() {
  if command_exists mihomo; then
    sudo mkdir -p "$CLASHTUI_INSTALL_DIR/mihomo"
    sudo ln -sf "$(which mihomo)" $CLASHTUI_INSTALL_DIR/mihomo/mihomo
  elif command_exists clash-meta; then
    sudo mkdir -p "$CLASHTUI_INSTALL_DIR/mihomo"
    sudo ln -sf "$(which clash-meta)" $CLASHTUI_INSTALL_DIR/mihomo/mihomo
  else
    download_mihomo
  fi

  create_mihomo_user
  sudo gpasswd -a $USER mihomo

  sudo chown mihomo:mihomo "$MIHOMO_CONFIG_DIR"
  create_mihomo_systemd_unit
}

download_singbox() {
  local arch=$(detect_architecture)
  local os=$(detect_os)
  local download_url
  local temp_dir=$(mktemp -d)
  local latest_version=$(curl -s "https://api.github.com/repos/SagerNet/sing-box/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

  if [ "$arch" = "unsupported" ] || [ "$os" = "unsupported" ]; then
    log_error "Unsupported architecture ($(uname -m)) or OS ($(uname -s))"
    rm -rf "$temp_dir"
    return 1
  fi

  download_url="https://github.com/SagerNet/sing-box/releases/latest/download/sing-box-${latest_version}-${os}-${arch}.tar.gz"

  log_info "Detected: OS=$os, Arch=$arch, LatestVersion=$latest_version, download_url=$download_url"

  curl -L "$download_url" -o "$temp_dir/sing-box.tar.gz"
  tar -xzf "$temp_dir/sing-box.tar.gz" -C "$temp_dir"

  local binary_path
  binary_path=$(find "$temp_dir" -name "sing-box" -type f | head -1)

  if [ -f "$binary_path" ]; then
    sudo mkdir -p "$CLASHTUI_INSTALL_DIR/sing-box"
    sudo install -m 755 "$binary_path" "$CLASHTUI_INSTALL_DIR/sing-box/sing-box"
    sudo ln -sf "$CLASHTUI_INSTALL_DIR/sing-box/sing-box" /usr/bin/sing-box
    log_info "Successfully installed sing-box to: $CLASHTUI_INSTALL_DIR/sing-box/sing-box"
  else
    log_error "Could not find sing-box binary in the downloaded archive"
    rm -rf "$temp_dir"
    return 1
  fi

  rm -rf "$temp_dir"
}

install_singbox() {
  if command_exists sing-box; then
    sudo mkdir -p "$CLASHTUI_INSTALL_DIR/sing-box"
    sudo ln -sf "$(which sing-box)" $CLASHTUI_INSTALL_DIR/sing-box/sing-box
    sudo ln -sf "$CLASHTUI_INSTALL_DIR/sing-box/sing-box" /usr/bin/sing-box
  else
    download_singbox
  fi

  create_singbox_user
  sudo gpasswd -a $USER sing-box

  sudo chown sing-box:sing-box "$SINGBOX_CONFIG_DIR"
  create_singbox_systemd_unit
}

create_singbox_config() {
  echo -n "Do you want to download sing-box config.json? (y/N): "
  read -r response
  if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
    log_info "Creating sing-box config.json..."

    sudo mkdir -p "$SINGBOX_CONFIG_DIR"
    sudo tee "$SINGBOX_CONFIG_DIR/config.json" >/dev/null <<'EOF'
{
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": ""
    }
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 7890
    }
  ],
  "log": {
    "level": "info"
  }
}
EOF

    mkdir -p "$SINGBOX_USER_CONFIG_DIR"
    sudo cp "$SINGBOX_CONFIG_DIR/config.json" "$SINGBOX_USER_CONFIG_DIR/basic_singbox_config.json"
    sudo chown "$USER:$(id -gn)" "$SINGBOX_USER_CONFIG_DIR/basic_singbox_config.json"
  else
    mkdir -p "$SINGBOX_USER_CONFIG_DIR"
    log_warn "Please create $SINGBOX_CONFIG_DIR/config.json manually before starting sing-box."
  fi
}

install_clashtui() {
  local core_type="$1"
  if ! command_exists clashtui; then
    download_clashtui
  fi

  create_clashtui_config "$core_type"
}

download_clashtui() {
  local arch=$(detect_architecture)
  local os=$(detect_os)
  local download_url
  local temp_dir=$(mktemp -d)
  local latest_version=$(curl -s "https://api.github.com/repos/JohanChane/clashtui/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

  if [ "$arch" = "unsupported" ] || [ "$os" = "unsupported" ]; then
    log_error "Unsupported architecture ($(uname -m)) or OS ($(uname -s))"
    rm -rf "$temp_dir"
    return 1
  fi

  download_url="https://github.com/JohanChane/clashtui/releases/latest/download/clashtui-${os}-${arch}-${latest_version}.gz"

  log_info "Detected: OS=$os, Arch=$arch, LatestVersion=$latest_version, download_url=$download_url"

  curl -L "$download_url" -o "$temp_dir/clashtui.gz"
  gunzip -c "$temp_dir/clashtui.gz" >"$temp_dir/clashtui"

  local binary_path
  if [ -f "$temp_dir/clashtui" ]; then
    binary_path="$temp_dir/clashtui"
  else
    log_error "Could not find binary in the downloaded archive"
    rm -rf "$temp_dir"
    return 1
  fi

  sudo install -m 755 "$binary_path" "$CLASHTUI_INSTALL_DIR/clashtui"
  sudo ln -sf "$CLASHTUI_INSTALL_DIR/clashtui" /usr/local/bin/clashtui
  log_info "Successfully installed clashtui to: $CLASHTUI_INSTALL_DIR/clashtui"
  rm -rf "$temp_dir"
}

uninstall() {
  echo "Please make sure the mihomo and sing-box daemons have been stopped before uninstallation."
  echo -n "Continue with uninstallation? (y/N): "
  read -r response
  if [ "$response" != "y" ] && [ "$response" != "Y" ]; then
    echo "Uninstallation cancelled."
    return 1
  fi

  sudo rm -f /etc/systemd/system/clashtui_mihomo.service
  sudo rm -f /usr/lib/systemd/system/clashtui_mihomo.service
  sudo rm -f /etc/systemd/system/clashtui_singbox.service
  sudo systemctl daemon-reload
  sudo rm -f /usr/local/bin/clashtui
  sudo rm -f /usr/bin/sing-box
  sudo rm -rf /opt/clashtui

  echo "[Optional] Delete the mihomo user and group"
  echo "  sudo gpasswd -d $USER mihomo"
  echo "  sudo userdel mihomo"
  echo "[Optional] Delete the sing-box user and group"
  echo "  sudo gpasswd -d $USER sing-box"
  echo "  sudo userdel sing-box"
}

CORE_TYPE="all"

show_help() {
  echo "Usage: $0 [OPTION]"
  echo "Install or uninstall clashtui"
  echo
  echo "Options:"
  echo "  -h, --help       Show this help message and exit"
  echo "  -u, --uninstall  Uninstall clashtui"
  echo "  --core <TYPE>    Select core to install: mihomo, sing-box, or all (default: all)"
  echo
  echo "If no options are provided, the script will install clashtui with all cores."
}

main() {
  while [[ $# -gt 0 ]]; do
    case $1 in
    -u | --uninstall)
      uninstall
      return 0
      ;;
    -h | --help)
      show_help
      return 0
      ;;
    --core)
      if [ -z "$2" ]; then
        log_error "--core requires a value: mihomo, sing-box, or all"
        exit 1
      fi
      case "$2" in
      mihomo | sing-box | all)
        CORE_TYPE="$2"
        shift
        ;;
      *)
        log_error "Invalid core type: $2. Valid values: mihomo, sing-box, all" >&2
        exit 1
        ;;
      esac
      ;;
    *)
      log_error "Unknown option"
      show_help
      return 1
      ;;
    esac
    shift
  done

  if [ "$CORE_TYPE" = "mihomo" ] || [ "$CORE_TYPE" = "all" ]; then
    sudo mkdir -p "$MIHOMO_CONFIG_DIR"
  fi
  if [ "$CORE_TYPE" = "sing-box" ] || [ "$CORE_TYPE" = "all" ]; then
    sudo mkdir -p "$SINGBOX_CONFIG_DIR"
  fi
  mkdir -p "$CLASHTUI_CONFIG_DIR"

  case "$CORE_TYPE" in
  mihomo)
    install_mihomo
    ;;
  sing-box)
    install_singbox
    ;;
  all)
    install_mihomo
    install_singbox
    ;;
  esac

  install_clashtui "$CORE_TYPE"

  log_info "Installed cores: $CORE_TYPE"
  log_warn 'Please log out and log back in for the group file permissions to take effect'
}

main "$@"
