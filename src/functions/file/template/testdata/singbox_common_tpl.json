{
  "proxy-providers": {
    "pvd": {
      "tpl_param": {},
      "type": "http",
      "interval": 3600,
      "url": "https://example.com/subscription.yaml",
      "health-check": {
        "enable": true,
        "url": "https://www.gstatic.com/generate_204",
        "interval": 300
      }
    }
  },
  "proxy-groups": [
    {
      "name": "Proxy",
      "type": "select",
      "proxies": [
        "DIRECT",
        "<Auto>",
        "REJECT"
      ]
    },
    {
      "name": "Auto",
      "type": "url-test",
      "tpl_param": {
        "providers": ["pvd"]
      },
      "url": "https://www.gstatic.com/generate_204",
      "interval": 300,
      "tolerance": 50
    },
    {
      "name": "Direct",
      "type": "select",
      "proxies": ["DIRECT"]
    }
  ],
  "rules": [
    "IP-CIDR,127.0.0.0/8,DIRECT",
    "IP-CIDR,10.0.0.0/8,DIRECT",
    "IP-CIDR,172.16.0.0/12,DIRECT",
    "IP-CIDR,192.168.0.0/16,DIRECT",
    "IP-CIDR,100.64.0.0/10,DIRECT",
    "IP-CIDR,224.0.0.0/4,DIRECT",
    "DOMAIN-SUFFIX,cn,Direct",
    "DOMAIN-KEYWORD,china,Direct",
    "DOMAIN-SUFFIX,local,Direct",
    "GEOSITE,cn,Direct",
    "GEOSITE,geolocation-!cn,Proxy",
    "GEOIP,CN,Direct",
    "MATCH,Proxy"
  ],
  "rule-providers": {
    "geosite-cn": {
      "type": "http",
      "behavior": "domain",
      "url": "https://github.com/SagerNet/sing-geosite/raw/refs/heads/rule-set/geosite-cn.srs",
      "path": "./rule-providers/geosite-cn.srs",
      "interval": 86400
    },
    "geosite-geolocation-!cn": {
      "type": "http",
      "behavior": "domain",
      "url": "https://github.com/SagerNet/sing-geosite/raw/refs/heads/rule-set/geosite-geolocation-!cn.srs",
      "path": "./rule-providers/geosite-geolocation-!cn.srs",
      "interval": 86400
    },
    "geoip-cn": {
      "type": "http",
      "behavior": "ipcidr",
      "url": "https://github.com/SagerNet/sing-geoip/raw/refs/heads/rule-set/geoip-cn.srs",
      "path": "./rule-providers/geoip-cn.srs",
      "interval": 86400
    }
  }
}
